# Copy to .env and adjust. All backend settings are prefixed VAJRA_.

# Location of the real datasets (defaults to ../datasets relative to the repo)
# VAJRA_DATASETS_DIR=/absolute/path/to/datasets

# Optional: Google Gemini API key enables natural-language explanations & chat.
# Without it, a deterministic explanation generator is used.
# VAJRA_GOOGLE_API_KEY=
VAJRA_GEMINI_MODEL=gemini-2.5-flash

# Correlation window for incident slicing (seconds)
# VAJRA_CORRELATION_WINDOW_S=300

# "config change within N seconds" causal bonus window
# VAJRA_CONFIG_CAUSAL_WINDOW_S=5

# API server
# VAJRA_HOST=0.0.0.0
# VAJRA_PORT=8000

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# VAJRA_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vajra_rca

# ── Neo4j ────────────────────────────────────────────────────────────────────
# VAJRA_NEO4J_URI=bolt://localhost:7687
# VAJRA_NEO4J_USER=neo4j
# VAJRA_NEO4J_PASSWORD=password

# ── Qdrant ───────────────────────────────────────────────────────────────────
# VAJRA_QDRANT_HOST=localhost
# VAJRA_QDRANT_PORT=6333

# ── Kafka ────────────────────────────────────────────────────────────────────
# VAJRA_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── MinIO ────────────────────────────────────────────────────────────────────
# VAJRA_MINIO_ENDPOINT=localhost:9000
# VAJRA_MINIO_ACCESS_KEY=minioadmin
# VAJRA_MINIO_SECRET_KEY=minioadmin
